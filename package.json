{
  "name": "scentiq",
  "version": "0.1.0",
  "private": true,
  "description": "ScentIQ — luxury perfume platform (Phase 1 foundation)",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20 <25",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write . --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "test": "node scripts/run-tests.mjs",
    "qa:audit": "node scripts/qa-audit.mjs",
    "ui:audit": "node scripts/ui-audit.mjs",
    "roadmap:audit": "node scripts/roadmap-audit.mjs",
    "step29:audit": "node scripts/step29-audit.mjs",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "qa:check": "pnpm qa:audit && pnpm ui:audit && pnpm roadmap:audit && pnpm step29:audit && pnpm prisma:generate && pnpm test && pnpm typecheck && pnpm lint && pnpm build && pnpm perf:budget",
    "doctor": "node scripts/doctor.mjs",
    "doctor:db": "node scripts/doctor.mjs --database",
    "env:check": "node scripts/doctor.mjs",
    "deploy:check": "node scripts/predeploy.mjs",
    "deploy:check:db": "prisma generate && node scripts/predeploy.mjs --database",
    "vercel-build": "node scripts/predeploy.mjs && prisma generate && next build",
    "release:check": "pnpm deploy:check && pnpm qa:audit && pnpm ui:audit && pnpm roadmap:audit && pnpm step29:audit && pnpm prisma:generate && pnpm test && pnpm typecheck && pnpm lint && pnpm build && pnpm perf:budget",
    "perf:budget": "node scripts/performance-budget.mjs",
    "verify": "pnpm prisma:generate && pnpm test && pnpm typecheck && pnpm lint && pnpm build && pnpm perf:budget",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed:core": "tsx prisma/seed.ts --mode=core",
    "seed:dev": "tsx prisma/seed.ts --mode=dev",
    "seed:staging": "tsx prisma/seed.ts --mode=staging",
    "seed:products": "tsx prisma/seed.ts --mode=products",
    "seed:production": "tsx prisma/seed.ts --mode=production",
    "db:reset": "node scripts/reset-local-database.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.23.0",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.5.16",
    "prettier": "^3.6.2",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.5",
    "typescript": "^5.9.3"
  }
}
