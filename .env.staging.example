# Safe template only. Store real values in the hosting provider, never Git.
SCENTIQ_ENVIRONMENT="staging"
SCENTIQ_SEED_MODE="staging"
DATABASE_URL="postgresql://STAGING_RUNTIME_USER:SECRET@STAGING_HOST:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://STAGING_MIGRATION_USER:SECRET@STAGING_HOST:5432/postgres?sslmode=require"
AUTH_SECRET="replace-with-a-unique-staging-secret-at-least-32-characters"
