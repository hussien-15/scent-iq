# Local PostgreSQL or Docker (recommended for development).
# Keep the database name ending in _dev so the guarded db:reset command can run.
DATABASE_URL="postgresql://scentiq:scentiq_local_password@localhost:5432/scentiq_dev?schema=public"
DIRECT_URL="postgresql://scentiq:scentiq_local_password@localhost:5432/scentiq_dev?schema=public"

# Supabase uses different URLs: the deployed app uses the 6543 transaction
# pooler for DATABASE_URL and migration/seed tools use the 5432 session pooler
# for DIRECT_URL. Follow DATABASE.md before touching an existing remote schema.

# Public production origin used for canonical links, structured data and sitemap.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Real-user Core Web Vitals sample. 0.1 means 10% of browser sessions.
NEXT_PUBLIC_WEB_VITAL_SAMPLE_RATE="0.1"

# Auth.js v5. AUTH_SECRET is the current name for NEXTAUTH_SECRET.
# Generate once with Node.js:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-random-secret-at-least-32-characters"
AUTH_URL="http://localhost:3000"

# Production must use HTTPS. The same AUTH_SECRET is used as the HMAC key for
# irreversible login/rate-limit identifiers; changing it invalidates sessions.

# Optional Google login (leave blank to disable)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cloudinary — collection covers and moderated review photos use the same account.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Step 21 — secure, allowlisted on-demand cache revalidation.
REVALIDATION_SECRET="replace-with-an-independent-random-secret"

# Step 25 deployment/runtime controls. Local development may leave these at
# their safe defaults; staging/production must use the matching environment.
STORAGE_PROVIDER="cloudinary"
MAINTENANCE_MODE="off"
ORDERING_DISABLED="false"
DEPLOYMENT_ID="local"
NEXT_PUBLIC_SUPPORT_WHATSAPP=""
NEXT_PUBLIC_SUPPORT_PHONE=""
NEXT_PUBLIC_SUPPORT_EMAIL=""

# Step 23 — safe, repeatable initial setup.
# Modes: core, dev, staging, products, demo, production.
# Production requires SEED_PRODUCTION_CONFIRM=SCENTIQ_PRODUCTION_SETUP.
SCENTIQ_SEED_MODE="dev"
SCENTIQ_ENVIRONMENT="development"
SEED_PRODUCTION_CONFIRM=""
SEED_ADMIN_NAME=""
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Future provider webhooks. The generic secret is a fallback; provider-specific
# values take precedence (DELIVERY, PAYMENT, NOTIFICATIONS).
WEBHOOK_SECRET=""
WEBHOOK_SECRET_DELIVERY=""
WEBHOOK_SECRET_PAYMENT=""
WEBHOOK_SECRET_NOTIFICATIONS=""

# Stripe (Phase 2 — checkout)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
