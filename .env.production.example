# Safe template only. Configure real values in Vercel/hosting settings.
SCENTIQ_ENVIRONMENT="production"
SCENTIQ_SEED_MODE="production"
DATABASE_URL="postgresql://PRODUCTION_RUNTIME_USER:SECRET@PRODUCTION_HOST:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://PRODUCTION_MIGRATION_USER:SECRET@PRODUCTION_HOST:5432/postgres?sslmode=require"
AUTH_SECRET="replace-with-a-unique-production-secret-at-least-32-characters"
AUTH_URL="https://scentiq.example"
NEXT_PUBLIC_SITE_URL="https://scentiq.example"
NEXT_PUBLIC_WEB_VITAL_SAMPLE_RATE="0.1"
REVALIDATION_SECRET="replace-with-a-different-production-secret"
STORAGE_PROVIDER="cloudinary"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
MAINTENANCE_MODE="off"
ORDERING_DISABLED="false"
DEPLOYMENT_ID="production"
NEXT_PUBLIC_SUPPORT_WHATSAPP=""
NEXT_PUBLIC_SUPPORT_PHONE=""
NEXT_PUBLIC_SUPPORT_EMAIL=""
SEED_PRODUCTION_CONFIRM=""
SEED_ADMIN_NAME=""
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
